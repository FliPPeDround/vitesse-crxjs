{
  "name": "vitesse-crxjs",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Vitesse for Chrome Extension with CRXJS",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@vueuse/shared": "^14.2.1",
    "vue": "^3.5.30",
    "webext-bridge": "^6.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@crxjs/vite-plugin": "^2.4.0",
    "@iconify-json/pixelarticons": "^1.2.4",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@unocss/eslint-plugin": "^66.6.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "@vueuse/core": "^14.2.1",
    "eslint": "^10.0.3",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "unocss": "^66.6.6",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-zip-pack": "^1.2.4",
    "vitest": "^4.1.0",
    "vitest-environment-web-ext": "^0.0.3",
    "vue-tsc": "^3.2.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
